<Window x:Class="BanketStoli.Wpf.Views.RoomDetailsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="БанкетСтоли — подробности комнаты" MinWidth="520" MinHeight="430" Width="620" Height="500" WindowStartupLocation="CenterOwner">
  <ScrollViewer Margin="18">
    <StackPanel>
      <TextBlock x:Name="NameTextBlock" FontSize="24" FontWeight="SemiBold"/>
      <TextBlock x:Name="StyleTextBlock" Margin="0,12,0,0"/>
      <TextBlock x:Name="TableCountTextBlock"/>
      <TextBlock x:Name="PriceTextBlock"/>
      <Border BorderBrush="#FFB79D87" BorderThickness="1" Height="180" Margin="0,14" Background="White">
        <Image x:Name="RoomImage" Stretch="Uniform"/><TextBlock x:Name="ImageTextBlock" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"/>
      </Border>
      <TextBlock Text="Описание" FontWeight="SemiBold" Margin="0,8,0,4"/>
      <TextBlock x:Name="DescriptionTextBlock" TextWrapping="Wrap"/>
      <Button Content="Закрыть" HorizontalAlignment="Right" Margin="0,16,0,0" Click="CloseButton_Click"/>
    </StackPanel>
  </ScrollViewer>
</Window>
