<Window x:Class="BanketStoli.Views.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="БанкетСтоли — банкетные комнаты" MinWidth="900" MinHeight="650" Width="1080" Height="720" WindowStartupLocation="CenterScreen">
  <DockPanel Margin="20">
    <Border DockPanel.Dock="Top" Background="White" Padding="16" Margin="0,0,0,16">
      <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <StackPanel><TextBlock Text="Каталог банкетных комнат" FontSize="26" FontWeight="SemiBold" Foreground="#FF3B2A20"/><TextBlock x:Name="UserTextBlock" Margin="0,4,0,0" Foreground="#FF7A6656"/></StackPanel>
        <TextBox Grid.Column="1" x:Name="SearchTextBox" Width="230" ToolTip="Поиск по названию и описанию" TextChanged="Filters_Changed"/>
        <ComboBox Grid.Column="2" x:Name="StyleComboBox" Width="190" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="Filters_Changed"/>
        <ComboBox Grid.Column="3" x:Name="SortComboBox" Width="220" SelectionChanged="Filters_Changed"><ComboBoxItem Content="Без сортировки" Tag="" IsSelected="True"/><ComboBoxItem Content="Стоимость по возрастанию" Tag="asc"/><ComboBoxItem Content="Стоимость по убыванию" Tag="desc"/></ComboBox>
        <Button Grid.Column="4" Content="Сменить пользователя" Click="ChangeUserButton_Click"/>
      </Grid>
    </Border>
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0"><Button x:Name="AddButton" Content="Добавить" Click="AddButton_Click"/><Button x:Name="EditButton" Content="Редактировать" Click="EditButton_Click"/><Button x:Name="DeleteButton" Content="Удалить" Click="DeleteButton_Click"/></StackPanel>
    <ListBox x:Name="RoomsGrid" BorderThickness="0" Background="Transparent" SelectionMode="Single" MouseDoubleClick="RoomsGrid_MouseDoubleClick" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
      <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Margin" Value="0,0,0,12"/><Setter Property="Padding" Value="0"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/></Style></ListBox.ItemContainerStyle>
      <ListBox.ItemTemplate><DataTemplate><Border Background="White" Padding="14"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Background="#FFF0E8DE" Height="110"><Grid><TextBlock Text="Фото не указано" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF9A7B63"/><Image Source="{Binding CurrentPhoto}" Stretch="UniformToFill"/></Grid></Border>
        <StackPanel Grid.Column="2"><TextBlock Text="{Binding Name}" FontSize="20" FontWeight="SemiBold" Foreground="#FF3B2A20"/><TextBlock Text="{Binding StyleName}" Foreground="#FF7A6656" Margin="0,4,0,0"/><WrapPanel Margin="0,10,0,0"><TextBlock Text="Столов: " FontWeight="SemiBold"/><TextBlock Text="{Binding TableCount}"/><TextBlock Text="   Стоимость: " FontWeight="SemiBold"/><TextBlock Text="{Binding RentPricePerHour, StringFormat={}{0:N2} руб./час}"/></WrapPanel><TextBlock Text="{Binding Description}" TextWrapping="Wrap" MaxHeight="42" Margin="0,8,0,0" Foreground="#FF5D5048"/></StackPanel>
      </Grid></Border></DataTemplate></ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</Window>
