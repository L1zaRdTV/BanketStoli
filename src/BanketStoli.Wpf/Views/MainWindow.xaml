<Window x:Class="BanketStoli.Wpf.Views.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="БанкетСтоли — банкетные комнаты" MinWidth="900" MinHeight="560" Width="1050" Height="650" WindowStartupLocation="CenterScreen">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
      <TextBlock x:Name="UserTextBlock" VerticalAlignment="Center" FontWeight="SemiBold" Width="270"/>
      <TextBox x:Name="SearchTextBox" Width="220" ToolTip="Поиск по названию и описанию" TextChanged="Filters_Changed"/>
      <ComboBox x:Name="StyleComboBox" Width="190" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="Filters_Changed"/>
      <ComboBox x:Name="SortComboBox" Width="210" SelectionChanged="Filters_Changed">
        <ComboBoxItem Content="Без сортировки" Tag="" IsSelected="True"/>
        <ComboBoxItem Content="Стоимость по возрастанию" Tag="asc"/>
        <ComboBoxItem Content="Стоимость по убыванию" Tag="desc"/>
      </ComboBox>
      <Button Content="Сменить пользователя" Click="ChangeUserButton_Click"/>
    </StackPanel>
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="AddButton" Content="Добавить" Click="AddButton_Click"/>
      <Button x:Name="EditButton" Content="Редактировать" Click="EditButton_Click"/>
      <Button x:Name="DeleteButton" Content="Удалить" Click="DeleteButton_Click"/>
    </StackPanel>
    <DataGrid x:Name="RoomsGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="RoomsGrid_MouseDoubleClick">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="1.2*"/>
        <DataGridTextColumn Header="Стиль оформления" Binding="{Binding StyleName}" Width="1.4*"/>
        <DataGridTextColumn Header="Количество столов" Binding="{Binding TableCount}" Width="*"/>
        <DataGridTextColumn Header="Стоимость аренды" Binding="{Binding RentPricePerHour, StringFormat={}{0:N2} руб./час}" Width="*"/>
        <DataGridTemplateColumn Header="Изображение" Width="1.2*"><DataGridTemplateColumn.CellTemplate><DataTemplate><Image Source="{Binding ImagePath}" Height="70" Stretch="Uniform" ToolTip="{Binding ImagePath}"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*"/>
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>
