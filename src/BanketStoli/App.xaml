<Application x:Class="BanketStoli.App" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:converters="clr-namespace:BanketStoli.Converters" StartupUri="Views/LoginWindow.xaml">
  <Application.Resources>
    <converters:ImagePathConverter x:Key="ImagePathConverter"/>
    <Style TargetType="Window">
      <Setter Property="FontFamily" Value="Segoe UI"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Background" Value="#FFF7F4EF"/>
    </Style>
    <Style TargetType="Button">
      <Setter Property="Margin" Value="4"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="MinWidth" Value="104"/>
      <Setter Property="Background" Value="#FF7A4E2D"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style TargetType="TextBox"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="8"/><Setter Property="BorderBrush" Value="#FFD6C3B2"/></Style>
    <Style TargetType="ComboBox"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="8"/><Setter Property="BorderBrush" Value="#FFD6C3B2"/></Style>
  </Application.Resources>
</Application>
