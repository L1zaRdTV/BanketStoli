<Window x:Class="BanketStoli.Wpf.Views.RoomEditWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="БанкетСтоли — карточка комнаты" MinWidth="540" MinHeight="560" Width="620" Height="620" WindowStartupLocation="CenterOwner">
  <Grid Margin="18"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel>
      <TextBlock Text="Название"/><TextBox x:Name="NameTextBox" MaxLength="80"/>
      <TextBlock Text="Стиль оформления"/><ComboBox x:Name="StyleComboBox" DisplayMemberPath="Name" SelectedValuePath="Id"/>
      <TextBlock Text="Количество столов"/><TextBox x:Name="TableCountTextBox"/>
      <TextBlock Text="Стоимость аренды, руб./час"/><TextBox x:Name="PriceTextBox"/>
      <TextBlock Text="Изображение"/><TextBox x:Name="ImagePathTextBox" MaxLength="260"/>
      <TextBlock Text="Описание"/><TextBox x:Name="DescriptionTextBox" MaxLength="1000" Height="130" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
    </StackPanel>
    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Сохранить" Click="SaveButton_Click"/><Button Content="Отмена" Click="CancelButton_Click"/></StackPanel>
  </Grid>
</Window>
