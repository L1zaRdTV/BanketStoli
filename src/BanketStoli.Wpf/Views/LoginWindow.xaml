<Window x:Class="BanketStoli.Wpf.Views.LoginWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="БанкетСтоли — авторизация" MinWidth="420" MinHeight="300" Width="460" Height="320" WindowStartupLocation="CenterScreen">
  <Grid Margin="24">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <TextBlock Text="Система «Бронирование банкетных комнат»" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,20"/>
    <StackPanel Grid.Row="1">
      <TextBlock Text="Логин"/>
      <TextBox x:Name="LoginTextBox" TabIndex="0"/>
      <TextBlock Text="Пароль" Margin="0,10,0,0"/>
      <PasswordBox x:Name="PasswordBox" Margin="4" Padding="6" TabIndex="1"/>
      <TextBlock Text="Тестовые учетные записи: client1/client1, manager1/manager1" Foreground="#FF6E625B" TextWrapping="Wrap" Margin="4,12"/>
    </StackPanel>
    <Button Grid.Row="2" Content="Войти" HorizontalAlignment="Right" Click="SignInButton_Click" TabIndex="2"/>
  </Grid>
</Window>
